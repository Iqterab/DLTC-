{
  "name": "BlogPost",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "coverImage": {
      "type": "string"
    },
    "publishDate": {
      "type": "string",
      "format": "date"
    },
    "isPublished": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "title",
    "content"
  ]
}
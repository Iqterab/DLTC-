{
  "name": "NoticeBoard",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "isPublished": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "title",
    "body"
  ]
}